{
  "version": 3,
  "description": "Canonical hook inventory. Renderers translate each record into the host's native format. Events use snake_case canonical ids and host allow-lists convert to native event keys. V3 records use explicit handler objects; v2 command records are accepted only as a compatibility path.",
  "shared": [
    {
      "id": "pre-tool-execution-guardian",
      "description": "Universal pre-tool guardrail. Blocks destructive invocations such as --no-verify, force-push-to-main, and wildcard home deletion. Opt out per-session with AGENT_FORGE_GUARDIAN=off.",
      "event": "pre_tool_use",
      "matcher": "Bash",
      "handler": {
        "type": "command",
        "command": "bash ~/Projects/_agent_forge/skills/global/telemetry-guardian/guardian.sh"
      },
      "targets": [
        "claude",
        "codex",
        "gemini"
      ],
      "timeout_ms": 5000,
      "status_message": "telemetry-guardian vetting tool invocation"
    },
    {
      "id": "prompt-auto-activator",
      "description": "Inspect user prompt for opt-in keyword triggers (caveman, terse, checkpoint) and emit an advisory recommending the matching skill. Advisory only; never blocks.",
      "event": "user_prompt_submit",
      "matcher": "",
      "handler": {
        "type": "command",
        "command": "bash ~/Projects/_agent_forge/skills/global/prompt-auto-activator/auto-activator.sh"
      },
      "targets": [
        "claude",
        "codex"
      ],
      "timeout_ms": 3000,
      "status_message": "prompt-auto-activator scanning user prompt for skill triggers"
    }
  ],
  "claude": [
    {
      "id": "memory-bridge-outbound-claude",
      "description": "Bridge canonical MEMORY.md into Claude's native machine-local auto-memory at session start.",
      "event": "session_start",
      "matcher": "",
      "handler": {
        "type": "command",
        "command": "python3 ~/Projects/_agent_forge/skills/global/memory-bridge/bridge.py outbound --project . --host claude"
      },
      "targets": [
        "claude"
      ],
      "async": true,
      "timeout_ms": 10000,
      "status_message": "memory-bridge outbound to Claude auto-memory"
    },
    {
      "id": "memory-bridge-inbound-claude",
      "description": "Import new Claude auto-memory notes back into canonical MEMORY.md at session stop.",
      "event": "stop",
      "matcher": "",
      "handler": {
        "type": "command",
        "command": "python3 ~/Projects/_agent_forge/skills/global/memory-bridge/bridge.py inbound --project . --host claude"
      },
      "targets": [
        "claude"
      ],
      "async": true,
      "timeout_ms": 30000,
      "status_message": "memory-bridge inbound from Claude auto-memory"
    },
    {
      "id": "example-http-audit",
      "enabled": false,
      "description": "Dormant v3 schema example for Claude HTTP hook rendering.",
      "event": "post_tool_use",
      "matcher": "Write|Edit",
      "handler": {
        "type": "http",
        "url": "http://127.0.0.1:9/agent-forge/example-hook",
        "headers": {},
        "allowed_env_vars": []
      },
      "targets": [
        "claude"
      ],
      "timeout_ms": 30000
    },
    {
      "id": "example-mcp-tool-audit",
      "enabled": false,
      "description": "Dormant v3 schema example for Claude MCP tool hook rendering.",
      "event": "post_tool_use",
      "matcher": "Write|Edit",
      "handler": {
        "type": "mcp_tool",
        "server": "example",
        "tool": "audit_file",
        "input": {
          "file_path": "${tool_input.file_path}"
        }
      },
      "targets": [
        "claude"
      ],
      "timeout_ms": 30000
    },
    {
      "id": "example-prompt-review",
      "enabled": false,
      "description": "Dormant v3 schema example for Claude prompt hook rendering.",
      "event": "stop",
      "matcher": "",
      "handler": {
        "type": "prompt",
        "prompt": "Review the hook input JSON and return a yes/no JSON decision.",
        "model": "fast"
      },
      "targets": [
        "claude"
      ],
      "timeout_ms": 30000
    },
    {
      "id": "example-agent-review",
      "enabled": false,
      "description": "Dormant v3 schema example for Claude agent hook rendering.",
      "event": "stop",
      "matcher": "",
      "handler": {
        "type": "agent",
        "prompt": "Inspect the changed files and report whether a policy issue exists."
      },
      "targets": [
        "claude"
      ],
      "timeout_ms": 60000
    }
  ],
  "codex": [
    {
      "id": "memory-bridge-outbound-codex",
      "description": "Bridge canonical MEMORY.md into a Codex-readable project sidecar at session start.",
      "event": "session_start",
      "matcher": "",
      "handler": {
        "type": "command",
        "command": "python3 ~/Projects/_agent_forge/skills/global/memory-bridge/bridge.py outbound --project . --host codex"
      },
      "targets": [
        "codex"
      ],
      "async": true,
      "timeout_ms": 10000,
      "status_message": "memory-bridge outbound to Codex sidecar"
    },
    {
      "id": "memory-bridge-inbound-codex",
      "description": "Import new Codex bridge sidecar notes back into canonical MEMORY.md at session stop.",
      "event": "stop",
      "matcher": "",
      "handler": {
        "type": "command",
        "command": "python3 ~/Projects/_agent_forge/skills/global/memory-bridge/bridge.py inbound --project . --host codex"
      },
      "targets": [
        "codex"
      ],
      "async": true,
      "timeout_ms": 30000,
      "status_message": "memory-bridge inbound from Codex sidecar"
    }
  ],
  "gemini": [
    {
      "id": "memory-bridge-outbound-gemini",
      "description": "Bridge canonical MEMORY.md into a Gemini project-local memory sidecar at session start.",
      "event": "session_start",
      "matcher": "",
      "handler": {
        "type": "command",
        "command": "python3 ~/Projects/_agent_forge/skills/global/memory-bridge/bridge.py outbound --project . --host gemini"
      },
      "targets": [
        "gemini"
      ],
      "async": true,
      "timeout_ms": 10000,
      "status_message": "memory-bridge outbound to Gemini sidecar"
    },
    {
      "id": "memory-bridge-inbound-gemini",
      "description": "Import new Gemini sidecar notes back into canonical MEMORY.md at session end.",
      "event": "stop",
      "matcher": "",
      "handler": {
        "type": "command",
        "command": "python3 ~/Projects/_agent_forge/skills/global/memory-bridge/bridge.py inbound --project . --host gemini"
      },
      "targets": [
        "gemini"
      ],
      "async": true,
      "timeout_ms": 30000,
      "status_message": "memory-bridge inbound from Gemini sidecar"
    }
  ]
}
