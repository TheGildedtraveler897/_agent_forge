      "roles": [
        "scaffold-planner",
        "bootstrap-executor",
        "post-bootstrap-verifier"
      ]
    },
    {
      "name": "delivery-team",
      "canonical_manifest": "teams/delivery-team.json",
      "purpose": "Plan, build, and review work in governed repos without collapsing into a single god agent.",
      "roles": [
        "architect-planner",
        "builder-implementer",
        "reviewer-tester"
      ]
    },
    {
      "name": "research-team",
      "canonical_manifest": "teams/research-team.json",
      "purpose": "Gather sources, triage evidence, and hand off a compact evidence pack instead of raw context sprawl.",
      "roles": [
        "research-scout",
        "source-triager",
        "evidence-packager"
      ]
    },
    {
      "name": "planning-team",
      "canonical_manifest": "teams/planning-team.json",
      "purpose": "Turn evidence and repo truth into decision-complete implementation briefs.",
      "roles": [
        "goal-clarifier",
        "plan-author",
        "execution-briefer"
      ]
    },
    {
      "name": "assessment-team",
      "canonical_manifest": "teams/assessment-team.json",
      "purpose": "Check outcomes for regressions, quality gaps, and evidence that the goal was actually met.",
      "roles": [
        "result-auditor",
        "regression-reviewer",
        "scorecard-writer"
      ]
    },
    {
      "name": "improvement-team",
      "canonical_manifest": "teams/improvement-team.json",
      "purpose": "Convert findings into prioritized improvements, doctrine updates, and the next clean iteration plan.",
      "roles": [
        "gap-prioritizer",
        "remediation-designer",
        "doctrine-updater"
      ]
    }
  ]
